          },
          {
            "type": "content",
            "emoji": "📐",
            "title": "Grid Basics",
            "box": {
              "code": "<!-- Basic grid structure -->\n<div class=\"container\">\n  <div class=\"row\">\n    <div class=\"col\">\n      Equal width column\n    </div>\n    <div class=\"col\">\n      Equal width column\n    </div>\n  </div>\n</div>\n\n<!-- Specified column widths -->\n<div class=\"container\">\n  <div class=\"row\">\n    <div class=\"col-8\">\n      Main content (8/12)\n    </div>\n    <div class=\"col-4\">\n      Sidebar (4/12)\n    </div>\n  </div>\n</div>\n\n<!-- Responsive grid -->\n<div class=\"container\">\n  <div class=\"row\">\n    <div class=\"col-12 col-md-8 col-lg-9\">\n      Full width on mobile, 8/12 on tablet, 9/12 on desktop\n    </div>\n    <div class=\"col-12 col-md-4 col-lg-3\">\n      Full width on mobile, 4/12 on tablet, 3/12 on desktop\n    </div>\n  </div>\n</div>",
              "title": "<strong>12-column responsive grid</strong>"
            }
          },
          {
            "type": "content",
            "emoji": "📱",
            "title": "Breakpoints",
            "box": {
              "code": "<!-- Breakpoint prefixes -->\nxs:  < 576px   (no prefix)\nsm:  ≥ 576px\nmd:  ≥ 768px\nlg:  ≥ 992px\nxl:  ≥ 1200px\nxxl: ≥ 1400px\n\n<!-- Usage examples -->\n<div class=\"col-12 col-sm-6 col-md-4 col-lg-3\">\n  Responsive column\n</div>\n\n<!-- Hiding elements -->\n<div class=\"d-none d-md-block\">\n  Hidden on mobile, visible on tablet+\n</div>\n\n<div class=\"d-block d-md-none\">\n  Visible only on mobile\n</div>\n\n<!-- Responsive text alignment -->\n<p class=\"text-start text-md-center text-lg-end\">\n  Responsive text alignment\n</p>",
              "title": "<strong>Responsive breakpoints</strong>"
            }
          }
        ]
