      {
        "id": "core-concepts",
        "title": "Core Concepts",
        "slides": [
          {
            "type": "topic-title",
            "title": "Keycloak Terminology"
          },
          {
            "type": "content",
            "emoji": "🏰",
            "title": "Realms",
            "box": {
              "code": "// Master Realm (admin)\n// → Company Realm\n//   → Web App Client\n//   → Mobile App Client\n//   → API Client",
              "title": "<strong>Logical security domains that isolate configurations</strong>"
            },
            "list": [
              {
                "emoji": "👑",
                "text": "<strong>Master Realm</strong> - Super admin realm"
              },
              {
                "emoji": "🏢",
                "text": "<strong>Application Realms</strong> - Isolated per organization/tenant"
              }
            ],
            "note": {
              "text": "<span class=\"emoji\">💡</span> Each realm has separate users, clients, and configurations"
            }
          },
          {
            "type": "content",
            "emoji": "📱",
            "title": "Clients",
            "box": {
              "list": [
                {
                  "emoji": "🔒",
                  "text": "<strong>Confidential</strong> - Server-side apps (web apps with backend)"
                },
                {
                  "emoji": "🌐",
                  "text": "<strong>Public</strong> - Client-side apps (SPA, mobile apps)"
                },
                {
                  "emoji": "🔑",
                  "text": "<strong>Bearer-only</strong> - APIs that only validate tokens"
                }
              ],
              "title": "<strong>Applications that use Keycloak for authentication</strong>"
            }
          },
          {
            "type": "content",
            "emoji": "👤",
            "title": "Users & Roles",
            "box": {
              "code": "// User: alice@company.com\n// Realm Roles: user, admin\n// Client Roles: read_data, write_data\n// Groups: developers, managers",
              "title": "<strong>User management and permission system</strong>"
            },
            "list": [
              {
                "emoji": "🎯",
                "text": "<strong>Realm Roles</strong> - Global permissions"
              },
              {
                "emoji": "📱",
                "text": "<strong>Client Roles</strong> - App-specific permissions"
              },
              {
                "emoji": "👥",
                "text": "<strong>Groups</strong> - Bulk role assignments"
              }
            ]
          }
        ]
      },
      {
        "id": "authentication",
        "title": "Authentication & Authorization",
        "slides": [
          {
            "type": "topic-title",
            "title": "Auth vs Authz"
          },
          {
            "type": "content",
            "emoji": "🔐",
            "title": "Authentication vs Authorization",
            "box": {
              "list": [
                {
                  "emoji": "🆔",
                  "text": "<strong>Authentication</strong> - Who are you? (Verifying identity)"
                },
                {
                  "emoji": "✅",
                  "text": "<strong>Authorization</strong> - What can you do? (Checking permissions)"
                }
              ],
              "title": "<strong>Understanding the difference</strong>"
            },
            "note": {
              "text": "<span class=\"emoji\">🔑</span> Keycloak handles both: AuthN + AuthZ = Complete IAM"
            }
          },
          {
            "type": "content",
            "emoji": "🔄",
            "title": "Authentication Flows",
            "box": {
              "code": "1. Username/Password\n2. Conditional MFA\n3. Terms & Conditions\n4. Required Actions\n5. Token Issued",
              "title": "<strong>Customizable login processes</strong>"
            },
            "list": [
              {
                "emoji": "📝",
                "text": "<strong>Browser Flow</strong> - Web app logins"
              },
              {
                "emoji": "🔌",
                "text": "<strong>Direct Grant Flow</strong> - API/REST logins"
              },
              {
                "emoji": "📱",
                "text": "<strong>Registration Flow</strong> - User signup process"
              }
            ]
          },
          {
            "type": "content",
            "emoji": "🔒",
            "title": "Multi-Factor Authentication",
            "box": {
              "title": "MFA Options",
              "list": [
                {
                  "emoji": "⏱️",
                  "text": "<strong>TOTP</strong> - Time-based One-Time Password (Google Authenticator)"
                },
                {
                  "emoji": "📧",
                  "text": "<strong>Email OTP</strong> - One-time codes via email"
                },
                {
                  "emoji": "📱",
                  "text": "<strong>SMS OTP</strong> - Codes via text message"
                },
                {
                  "emoji": "🔑",
                  "text": "<strong>WebAuthn</strong> - Biometric & security keys"
                }
              ]
            }
          }
        ]
      },
      {
        "id": "tokens",
        "title": "Tokens & Protocols",
        "slides": [
          {
            "type": "topic-title",
            "title": "Tokens & Security Protocols"
          },
          {
            "type": "content",
            "emoji": "🎫",
            "title": "JWT Tokens",
            "box": {
              "code": "{\n  \"iss\": \"keycloak-server\",\n  \"sub\": \"user123\",\n  \"preferred_username\": \"alice\",\n  \"email\": \"alice@company.com\",\n  \"realm_access\": { \"roles\": [\"user\", \"admin\"] },\n  \"exp\": 1672531200\n}",
              "title": "<strong>JSON Web Tokens - The authentication standard</strong>"
            },
            "list": [
              {
                "emoji": "🔑",
                "text": "<strong>Access Token</strong> - API authorization (short-lived)"
              },
              {
                "emoji": "🔄",
                "text": "<strong>Refresh Token</strong> - Get new access tokens (long-lived)"
              },
              {
                "emoji": "🆔",
                "text": "<strong>ID Token</strong> - User identity information (OIDC)"
              }
            ]
          },
          {
            "type": "content",
            "emoji": "🌐",
            "title": "OAuth2 vs OpenID Connect",
            "box": {
              "list": [
                {
                  "emoji": "🔐",
                  "text": "<strong>OAuth 2.0</strong> - Authorization framework (WHAT you can access)"
                },
                {
                  "emoji": "🆔",
                  "text": "<strong>OpenID Connect</strong> - Authentication layer (WHO you are)"
                }
              ],
              "title": "<strong>Understanding the protocols</strong>"
            },
            "note": {
              "text": "<span class=\"emoji\">💡</span> OIDC = OAuth 2.0 + Identity Information"
            }
          },
          {
            "type": "content",
            "emoji": "📋",
            "title": "SAML 2.0 Support",
            "box": {
              "list": [
                {
                  "emoji": "🏢",
                  "text": "<strong>Identity Provider</strong> - Keycloak acts as IdP"
                },
                {
                  "emoji": "🌐",
                  "text": "<strong>Service Provider</strong> - Keycloak acts as SP"
                },
                {
                  "emoji": "🔄",
                  "text": "<strong>Bridge</strong> - Connect SAML and OIDC worlds"
                }
              ],
              "title": "<strong>Enterprise identity protocol</strong>"
            }
          }
        ]
      },
      {
        "id": "installation",
        "title": "Installation & Setup",
        "slides": [
          {
            "type": "topic-title",
            "title": "Getting Started with Keycloak"
          },
          {
            "type": "content",
            "emoji": "🐳",
            "title": "Docker Installation",
            "box": {
              "code": "docker run -p 8080:8080 \\\n  -e KEYCLOAK_ADMIN=admin \\\n  -e KEYCLOAK_ADMIN_PASSWORD=admin \\\n  quay.io/keycloak/keycloak:latest \\\n  start-dev",
              "title": "<strong>Quick start with Docker</strong>"
            },
            "note": {
              "text": "<span class=\"emoji\">⚡</span> Development mode with H2 database - not for production!"
            }
          },
          {
            "type": "content",
            "emoji": "🗄️",
            "title": "Production Database Setup",
            "box": {
              "title": "Supported Databases",
              "list": [
                {
                  "emoji": "🐘",
                  "text": "<strong>PostgreSQL</strong> - Recommended for production"
                },
                {
                  "emoji": "🐬",
                  "text": "<strong>MySQL</strong> - Enterprise friendly"
                },
                {
                  "emoji": "🔷",
                  "text": "<strong>MariaDB</strong> - MySQL alternative"
                },
                {
                  "emoji": "💎",
                  "text": "<strong>Oracle</strong> - Enterprise databases"
                }
              ]
            }
          },
          {
            "type": "content",
            "emoji": "☸️",
            "title": "Kubernetes Deployment",
            "box": {
              "code": "helm repo add bitnami https://charts.bitnami.com/bitnami\nhelm install keycloak bitnami/keycloak \\\n  --set auth.adminUser=admin \\\n  --set auth.adminPassword=admin",
              "title": "<strong>Helm chart installation</strong>"
            }
          }
        ]
      },
      {
        "id": "integrations",
        "title": "Integrations",
        "slides": [
          {
            "type": "topic-title",
            "title": "Application Integrations"
          },
          {
            "type": "content",
            "emoji": "🌐",
            "title": "Frontend Integration",
            "box": {
              "title": "SPA Applications (React, Angular, Vue)",
              "code": "// keycloak-js adapter\nimport Keycloak from 'keycloak-js';\n\nconst keycloak = new Keycloak({\n  url: 'https://keycloak.company.com',\n  realm: 'myrealm',\n  clientId: 'myapp'\n});\n\nawait keycloak.init({ onLoad: 'login-required' });"
            }
          },
          {
            "type": "content",
            "emoji": "☕",
            "title": "Spring Boot Integration",
            "box": {
              "code": "// application.properties\nkeycloak.auth-server-url=https://keycloak.company.com\nkeycloak.realm=myrealm\nkeycloak.resource=myapp\nkeycloak.public-client=true\nkeycloak.principal-attribute=preferred_username",
              "title": "<strong>Java/Spring Boot setup</strong>"
            },
            "list": [
              {
                "emoji": "📦",
                "text": "Add keycloak-spring-boot-starter"
              },
              {
                "emoji": "🔒",
                "text": "Use @RolesAllowed annotations"
              }
            ]
          },
          {
            "type": "content",
            "emoji": "🔌",
            "title": ".NET Integration",
            "box": {
              "code": "services.AddAuthentication(JwtBearerDefaults.AuthenticationScheme)\n  .AddJwtBearer(options =>\n  {\n    options.Authority = \"https://keycloak.company.com\";\n    options.Audience = \"myapp\";\n  });",
              "title": "<strong>ASP.NET Core setup</strong>"
            }
          }
        ]
      },
