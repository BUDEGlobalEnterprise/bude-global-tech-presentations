      {
        "id": "graph-foundations",
        "title": "1. Graph Foundations",
        "slides": [
          {
            "type": "topic-title",
            "title": "1. Why Graphs?",
            "subtitle": "The world is connected, not just tabular."
          },
          {
            "type": "content",
            "title": "Relation-First Design",
            "box": {
              "list": [
                {
                  "emoji": "🕸️",
                  "text": "<strong>Native Graph Processing:</strong> No JOINs; use pointers to traverse neighbors."
                },
                {
                  "emoji": "⚡",
                  "text": "<strong>Index-Free Adjacency:</strong> Constant time traversal regardless of total data size."
                }
              ],
              "title": "Unlike Relational DBs, relationships are first-class citizens in Neo4j."
            }
          }
        ]
      },
      {
        "id": "labeled-property-graph",
        "title": "2. The Labeled Property Graph (LPG)",
        "slides": [
          {
            "type": "topic-title",
            "title": "2. The LPG Model",
            "subtitle": "Nodes, Relationships, and Properties."
          },
          {
            "type": "content",
            "title": "Core Components",
            "box": {
              "list": [
                {
                  "emoji": "🔵",
                  "text": "<strong>Nodes:</strong> Represent entities (e.g., User, Product)."
                },
                {
                  "emoji": "➡️",
                  "text": "<strong>Relationships:</strong> Connect nodes with direction and type (e.g., LIKES, BOUGHT)."
                },
                {
                  "emoji": "🏷️",
                  "text": "<strong>Labels:</strong> Categorize nodes."
                },
                {
                  "emoji": "📝",
                  "text": "<strong>Properties:</strong> Key-value pairs on both nodes and relationships."
                }
              ]
            }
          }
        ]
      },
      {
        "id": "cypher-query-language",
        "title": "3. Cypher Query Language",
        "slides": [
          {
            "type": "topic-title",
            "title": "3. Cypher",
            "subtitle": "ASCII art for patterns."
          },
          {
            "type": "content",
            "title": "Pattern Matching",
            "box": {
              "code": "MATCH (u:User)-[:FOLLOWS]->(m:User)\nWHERE u.name = 'Alice'\nRETURN m.name",
              "title": "A declarative approach to graph querying."
            }
          },
          {
            "type": "content",
            "title": "The MERGE Clause",
            "box": {
              "list": [
                {
                  "emoji": "🔗",
                  "text": "<strong>Safety:</strong> Ensures unique nodes and relationships without duplicates."
                }
              ],
              "title": "The 'Get or Create' pattern."
            }
          },
          {
            "type": "content",
            "title": "Variable Length Paths",
            "box": {
              "code": "MATCH (u:User)-[:FOLLOWS*1..3]->(f:User)\nRETURN f",
              "title": "Querying connections of arbitrary depth."
            }
          }
        ]
      },
      {
        "id": "traversal-internals",
        "title": "4. Traversal Internals",
        "slides": [
          {
            "type": "topic-title",
            "title": "4. How Traversal Works",
            "subtitle": "Pointers and adjacency."
          },
          {
            "type": "content",
            "title": "Index-Free Adjacency",
            "box": {
              "list": [
                {
                  "emoji": "🏎️",
                  "text": "<strong>Speed:</strong> O(1) jump to the next node; no lookups required."
                }
              ],
              "title": "Storing pointers to neighbors directly on the node record."
            }
          },
          {
            "type": "content",
            "title": "Query Execution Plan",
            "box": {
              "list": [
                {
                  "emoji": "🗺️",
                  "text": "<strong>Planner:</strong> Determines the best starting point (Entry Node) using indexes."
                },
                {
                  "emoji": "🕹️",
                  "text": "<strong>Expander:</strong> Iterates over relationship pointers."
                }
              ],
              "title": "Interpreting Cypher into traversals."
            }
          }
        ]
      },
      {
        "id": "data-modeling-patterns",
        "title": "5. Graph Data Modeling",
        "slides": [
          {
            "type": "topic-title",
            "title": "5. Modeling Patterns",
            "subtitle": "Nodes vs. Relationships."
          },
          {
            "type": "content",
            "title": "Entity vs Relationship",
            "box": {
              "list": [
                {
                  "emoji": "🔵",
                  "text": "<strong>Node:</strong> For things that exist independently."
                },
                {
                  "emoji": "➡️",
                  "text": "<strong>Relationship:</strong> For the context of the connection (e.g., timestamp, weight)."
                }
              ],
              "title": "When to use a node vs a relationship property."
            }
          },
          {
            "type": "content",
            "title": "Anti-Patterns",
            "box": {
              "list": [
                {
                  "emoji": "🚫",
                  "text": "<strong>Dense Nodes:</strong> Nodes with millions of relationships (Hotspots)."
                }
              ],
              "title": "Common pitfalls in graph design."
            }
          }
        ]
      },
