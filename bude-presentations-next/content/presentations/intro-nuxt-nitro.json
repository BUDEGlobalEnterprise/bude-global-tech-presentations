                  "emoji": "🚀",
                  "text": "<strong>Seamless:</strong> User sees the final state immediately."
                }
              ],
              "title": "How Nuxt ensures that the state you set on the server is available in the browser without re-fetching."
            }
          },
          {
            "type": "content",
            "title": "Shared Composables",
            "box": {
              "code": "// composables/useAuth.js\nexport const useAuth = () => useState('auth', () => ({ user: null }));",
              "title": "Defining reusable logic and state in the `composables/` directory."
            }
          }
        ]
