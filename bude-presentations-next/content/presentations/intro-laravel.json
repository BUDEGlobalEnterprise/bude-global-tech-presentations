      {
        "id": "advanced-features",
        "title": "9. Advanced Features",
        "slides": [
          {
            "type": "topic-title",
            "title": "9. Advanced Features",
            "subtitle": "Events, Observers, and Collections."
          },
          {
            "type": "content",
            "title": "Events & Listeners",
            "box": {
              "code": "OrderShipped::dispatch($order);\n\n// In EventServiceProvider\n'OrderShipped' => [\n    'SendShipmentNotification',\n]",
              "title": "Decouple your application logic by using Laravel's event system."
            }
          },
          {
            "type": "content",
            "title": "Eloquent Observers",
            "box": {
              "code": "class UserObserver {\n    public function created(User $user) {\n        // Logic after user creation\n    }\n}",
              "title": "Group all of your Eloquent listeners into a single class."
            }
          },
          {
            "type": "content",
            "title": "Macroable Classes",
            "box": {
              "code": "Response::macro('caps', function ($value) {\n    return Response::make(strtoupper($value));\n});",
              "title": "Many of Laravel's core classes are 'macroable', allowing you to add custom methods at runtime."
            }
          }
        ]
