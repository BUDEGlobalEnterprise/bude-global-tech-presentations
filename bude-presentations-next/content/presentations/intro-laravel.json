          {
            "type": "content",
            "title": "Form Request Validation",
            "box": {
              "code": "public function rules() {\n    return [\n        'title' => 'required|unique:posts|max:255',\n        'body' => 'required',\n    ];\n}",
              "title": "Keep your controllers clean by offloading validation logic to dedicated Form Request classes."
            }
          },
          {
            "type": "content",
            "title": "Validation Rules ()",
            "box": {
              "list": [
                {
                  "emoji": "📧",
                  "text": "<code>email:rfc,dns</code> - Advanced email validation."
                },
                {
                  "emoji": "🛡️",
                  "text": "<code>prohibited_if</code> - Conditional logic for complex forms."
                },
                {
                  "emoji": "🎨",
                  "text": "<code>Rule::unique()</code> - Fluent rule builder."
                }
              ],
              "title": "Laravel includes over 90 validation rules out of the box, plus the ability to create custom ones."
            }
          },
          {
            "type": "content",
            "title": "Custom Middlewares",
            "box": {
              "code": "public function handle($request, Closure $next) {\n    if ($request->age <= 200) {\n        return redirect('home');\n    }\n    return $next($request);\n}",
              "title": "Middlewares provide a convenient mechanism for inspecting and filtering HTTP requests entering your application."
            }
          }
        ]
