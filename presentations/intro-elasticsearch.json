          {
            "type": "topic-title",
            "title": "2. Apache Lucene",
            "subtitle": "The engine under the hood."
          },
          {
            "type": "content",
            "title": "The Inverted Index",
            "box": {
              "list": [
                {
                  "emoji": "📑",
                  "text": "<strong>Structure:</strong> A mapping of terms to the documents that contain them."
                },
                {
                  "emoji": "🏗️",
                  "text": "<strong>Bkd-Trees:</strong> Used for numeric and geo-point data."
                }
              ],
              "title": "How Lucene makes search so fast."
            }
          },
          {
            "type": "content",
            "title": "Segments & Immutability",
            "box": {
              "list": [
                {
                  "emoji": "🧱",
                  "text": "<strong>Segments:</strong> Individual inverted indexes that are immutable."
                },
                {
                  "emoji": "🔄",
                  "text": "<strong>Merging:</strong> Background tasks merge small segments into larger ones."
                }
              ],
              "title": "Lucene indices are composed of multiple segments."
            }
          }
        ]
      },
      {
        "id": "distributed-architecture",
        "title": "3. Distributed Architecture",
        "slides": [
          {
            "type": "topic-title",
            "title": "3. Shards & Replicas",
            "subtitle": "Scaling storage and search throughput."
          },
          {
            "type": "content",
            "title": "What is a Shard?",
            "box": {
              "list": [
                {
                  "emoji": "🏗️",
                  "text": "<strong>Primary Shards:</strong> Original data home. Fixed at index creation time."
                },
                {
                  "emoji": "👥",
                  "text": "<strong>Replica Shards:</strong> Copies for failover and read throughput."
                }
              ],
              "title": "A single Lucene index. An Elasticsearch index is a collection of shards."
            }
          },
          {
            "type": "content",
            "title": "Cluster State & Master Node",
            "box": {
              "list": [
                {
                  "emoji": "👑",
                  "text": "<strong>Master Node:</strong> Manages index creation and node membership."
                },
                {
                  "emoji": "📡",
                  "text": "<strong>Data Nodes:</strong> Store the shards and execute queries."
                }
              ],
              "title": "How nodes coordinate."
            }
          }
        ]
      },
      {
        "id": "indexing-process",
        "title": "4. The Indexing Path",
        "slides": [
          {
            "type": "topic-title",
            "title": "4. Writing Data",
            "subtitle": "How a document becomes searchable."
          },
          {
            "type": "content",
            "title": "The Lifecycle of a Write",
            "box": {
              "list": [
                {
                  "emoji": "🗳️",
                  "text": "<strong>Coordination:</strong> Request hits a node, which routes to the Primary Shard."
                },
                {
                  "emoji": "📝",
                  "text": "<strong>Primary Write:</strong> Local write to Lucene + Translog."
                },
                {
                  "emoji": "📡",
                  "text": "<strong>Replication:</strong> Parallel write to all replica shards."
                }
              ]
            }
          },
          {
            "type": "content",
            "title": "The Refresh Mechanism",
            "box": {
              "list": [
                {
                  "emoji": "🔄",
                  "text": "<strong>Refresh:</strong> Moving data from memory buffer to a new Lucene segment (default 1s)."
                },
                {
                  "emoji": "💾",
                  "text": "<strong>Flush:</strong> Committing segments to disk and clearing the Translog."
                }
              ],
              "title": "Near Real-Time (NRT) search."
            }
          }
        ]
      },
      {
        "id": "mapping-analyzers",
        "title": "5. Mapping & Analyzers",
        "slides": [
          {
            "type": "topic-title",
            "title": "5. Text Processing",
            "subtitle": "Turning raw text into searchable tokens."
