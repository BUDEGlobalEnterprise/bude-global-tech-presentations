            "type": "content",
            "title": "The Analyzer Pipeline",
            "box": {
              "list": [
                {
                  "emoji": "✂️",
                  "text": "<strong>Character Filters:</strong> Stripping HTML or regex."
                },
                {
                  "emoji": "🧩",
                  "text": "<strong>Tokenizer:</strong> Splitting text into words (e.g., standard, whitespace)."
                },
                {
                  "emoji": "🛠️",
                  "text": "<strong>Token Filters:</strong> Lowercasing, stemming, stop-words, synonyms."
                }
              ]
            }
          },
          {
            "type": "content",
            "title": "Dynamic vs Static Mapping",
            "box": {
              "code": "PUT /users\n{\n  \"mappings\": {\n    \"properties\": {\n      \"bio\": { \"type\": \"text\", \"analyzer\": \"english\" }\n    }\n  }\n}",
              "title": "Defining your schema."
            }
          }
        ]
