      {
        "id": "es-foundations",
        "title": "1. Elasticsearch Foundations",
        "slides": [
          {
            "type": "topic-title",
            "title": "1. What is Elasticsearch?",
            "box": { "content": "The Heart of the Elastic Stack." }
          },
          {
            "type": "content",
            "title": "Defining Features",
            "box": {
              "content": "A distributed, RESTful search and analytics engine built on Apache Lucene.",
              "list": [
                { "emoji": "🔍", "text": "<strong>Full-Text Search:</strong> Fast, relevant results." },
                { "emoji": "📊", "text": "<strong>Analytics:</strong> Aggregations for real-time data insights." },
                { "emoji": "🌐", "text": "<strong>Distributed:</strong> Horizontal scaling for petabytes of data." }
              ]
            }
          }
        ]
      },
      {
        "id": "search-internals",
        "title": "2. Search Internals: Lucene",
        "slides": [
          {
            "type": "topic-title",
            "title": "2. Apache Lucene",
            "box": { "content": "The engine under the hood." }
          },
          {
            "type": "content",
            "title": "The Inverted Index",
            "box": {
              "content": "How Lucene makes search so fast.",
              "list": [
                { "emoji": "📑", "text": "<strong>Structure:</strong> A mapping of terms to the documents that contain them." },
                { "emoji": "🏗️", "text": "<strong>Bkd-Trees:</strong> Used for numeric and geo-point data." }
              ]
            }
          },
          {
            "type": "content",
            "title": "Segments & Immutability",
            "box": {
              "content": "Lucene indices are composed of multiple segments.",
              "list": [
                { "emoji": "🧱", "text": "<strong>Segments:</strong> Individual inverted indexes that are immutable." },
                { "emoji": "🔄", "text": "<strong>Merging:</strong> Background tasks merge small segments into larger ones." }
              ]
            }
          }
        ]
      },
      {
        "id": "distributed-architecture",
        "title": "3. Distributed Architecture",
        "slides": [
          {
            "type": "topic-title",
            "title": "3. Shards & Replicas",
            "box": { "content": "Scaling storage and search throughput." }
          },
          {
            "type": "content",
            "title": "What is a Shard?",
            "box": {
              "content": "A single Lucene index. An Elasticsearch index is a collection of shards.",
              "list": [
                { "emoji": "🏗️", "text": "<strong>Primary Shards:</strong> Original data home. Fixed at index creation time." },
                { "emoji": "👥", "text": "<strong>Replica Shards:</strong> Copies for failover and read throughput." }
              ]
            }
          },
          {
            "type": "content",
            "title": "Cluster State & Master Node",
            "box": {
              "content": "How nodes coordinate.",
              "list": [
                { "emoji": "👑", "text": "<strong>Master Node:</strong> Manages index creation and node membership." },
                { "emoji": "📡", "text": "<strong>Data Nodes:</strong> Store the shards and execute queries." }
              ]
            }
          }
        ]
      },
      {
        "id": "indexing-process",
        "title": "4. The Indexing Path",
        "slides": [
          {
            "type": "topic-title",
            "title": "4. Writing Data",
            "box": { "content": "How a document becomes searchable." }
          },
          {
            "type": "content",
            "title": "The Lifecycle of a Write",
            "box": {
              "list": [
                { "emoji": "🗳️", "text": "<strong>Coordination:</strong> Request hits a node, which routes to the Primary Shard." },
                { "emoji": "📝", "text": "<strong>Primary Write:</strong> Local write to Lucene + Translog." },
                { "emoji": "📡", "text": "<strong>Replication:</strong> Parallel write to all replica shards." }
              ]
            }
          },
          {
            "type": "content",
            "title": "The Refresh Mechanism",
            "box": {
              "content": "Near Real-Time (NRT) search.",
              "list": [
                { "emoji": "🔄", "text": "<strong>Refresh:</strong> Moving data from memory buffer to a new Lucene segment (default 1s)." },
                { "emoji": "💾", "text": "<strong>Flush:</strong> Committing segments to disk and clearing the Translog." }
              ]
            }
          }
        ]
      },
      {
        "id": "mapping-analyzers",
        "title": "5. Mapping & Analyzers",
        "slides": [
          {
            "type": "topic-title",
            "title": "5. Text Processing",
            "box": { "content": "Turning raw text into searchable tokens." }
          },
          {
            "type": "content",
            "title": "The Analyzer Pipeline",
            "box": {
              "list": [
                { "emoji": "✂️", "text": "<strong>Character Filters:</strong> Stripping HTML or regex." },
                { "emoji": "🧩", "text": "<strong>Tokenizer:</strong> Splitting text into words (e.g., standard, whitespace)." },
                { "emoji": "🛠️", "text": "<strong>Token Filters:</strong> Lowercasing, stemming, stop-words, synonyms." }
              ]
            }
          },
          {
            "type": "content",
            "title": "Dynamic vs Static Mapping",
            "box": {
              "content": "Defining your schema.",
              "code": "PUT /users\n{\n  \"mappings\": {\n    \"properties\": {\n      \"bio\": { \"type\": \"text\", \"analyzer\": \"english\" }\n    }\n  }\n}"
            }
          }
        ]
      },
      {
        "id": "query-dsl",
        "title": "6. Query DSL",
        "slides": [
          {
            "type": "topic-title",
            "title": "6. Query DSL",
            "box": { "content": "The power of Boolean Search." }
          },
          {
            "type": "content",
            "title": "Match vs Term Query",
            "box": {
              "list": [
                { "emoji": "🔤", "text": "<strong>Match:</strong> Full-text search (analyzed). Good for bios, descriptions." },
                { "emoji": "🎯", "text": "<strong>Term:</strong> Exact value match (non-analyzed). Good for IDs, tags." }
              ]
            }
          },
          {
            "type": "content",
            "title": "Boolean Compound Queries",
            "box": {
              "content": "Combining multiple criteria.",
              "code": "GET /users/_search\n{\n  \"query\": {\n    \"bool\": {\n      \"must\": [{ \"match\": { \"bio\": \"developer\" }}],\n      \"filter\": [{ \"term\": { \"status\": \"active\" }}]\n    }\n  }\n}"
            }
          },
          {
            "type": "content",
            "title": "Range & Prefix Queries",
            "box": {
              "list": [
                { "emoji": "📏", "text": "<strong>Range:</strong> Greater than, Less than (gt, gte, lt, lte)." },
                { "emoji": "🔡", "text": "<strong>Prefix:</strong> Autocomplete-lite search." }
              ]
            }
          },
          {
            "type": "content",
            "title": "Fuzzy & Wildcard",
            "box": {
              "content": "Handling typos and patterns.",
              "list": [
                { "emoji": "🥴", "text": "<strong>Fuzzy:</strong> Levenshtein distance for spell correction." }
              ]
            }
          }
        ]
      },
