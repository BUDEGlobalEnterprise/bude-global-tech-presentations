                  "emoji": "🎯",
                  "text": "<strong>Term:</strong> Exact value match (non-analyzed). Good for IDs, tags."
                }
              ]
            }
          },
          {
            "type": "content",
            "title": "Boolean Compound Queries",
            "box": {
              "code": "GET /users/_search\n{\n  \"query\": {\n    \"bool\": {\n      \"must\": [{ \"match\": { \"bio\": \"developer\" }}],\n      \"filter\": [{ \"term\": { \"status\": \"active\" }}]\n    }\n  }\n}",
              "title": "Combining multiple criteria."
            }
          },
          {
            "type": "content",
            "title": "Range & Prefix Queries",
            "box": {
              "list": [
                {
                  "emoji": "📏",
                  "text": "<strong>Range:</strong> Greater than, Less than (gt, gte, lt, lte)."
                },
                {
                  "emoji": "🔡",
                  "text": "<strong>Prefix:</strong> Autocomplete-lite search."
                }
              ]
            }
          },
          {
