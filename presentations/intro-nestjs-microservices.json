      },
      {
        "id": "nestjs-foundations",
        "title": "1. NestJS Foundations",
        "slides": [
          {
            "type": "topic-title",
            "title": "1. Solid Grounding",
            "box": { "content": "The philosophy and core concepts of NestJS." }
          },
          {
            "type": "content",
            "title": "What is NestJS?",
            "box": {
              "content": "Nest is built on top of Express or Fastify, providing an out-of-the-box application architecture.",
              "list": [
                { "emoji": "📜", "text": "<strong>TypeScript:</strong> Built with and for TypeScript." },
                { "emoji": "🧩", "text": "<strong>Modular:</strong> Encourages encapsulation and separation of concerns." }
              ]
            }
          },
          {
            "type": "content",
            "title": "Dependency Injection (DI)",
            "box": {
              "content": "A core architectural pattern for managing object creation and lifecycle.",
              "code": "@Injectable()\nexport class UsersService { ... }"
            }
          },
          {
            "type": "content",
            "title": "Decorators",
            "box": {
              "content": "Using TypeScript decorators for clean, declarative meta-programming.",
              "code": "@Controller('users')\nexport class UsersController { ... }"
            }
          },
          {
            "type": "content",
            "title": "The Modular System",
            "box": {
              "content": "Every Nest application has at least one module (the root module).",
              "code": "@Module({\n    controllers: [UsersController],\n    providers: [UsersService],\n})\nexport class UsersModule {}"
            }
          }
        ]
      },
      {
        "id": "nestjs-architecture",
        "title": "2. Architecture Patterns",
        "slides": [
          {
            "type": "topic-title",
            "title": "2. Inside the Box",
            "box": { "content": "Mastering Controllers, Providers, and Pipes." }
          },
          {
            "type": "content",
            "title": "Controllers",
            "box": {
              "content": "Responsible for handling incoming requests and returning responses to the client.",
              "code": "@Get()\nfindAll(@Query() query: ListAllEntities) {\n    return `This action returns all cats (limit: ${query.limit} items)`;\n}"
            }
          },
          {
            "type": "content",
            "title": "Providers",
            "box": {
              "content": "Almost everything in Nest is a provider: services, repositories, factories, helpers, etc.",
              "list": [
                { "emoji": "💉", "text": "<strong>Injected:</strong> Can be injected into other classes via constructors." },
                { "emoji": "🔄", "text": "<strong>Lifecycle:</strong> Managed by the Nest IoC container." }
              ]
            }
          },
          {
            "type": "content",
            "title": "Pipes & Validation",
            "box": {
              "content": "Use pipes for transformation and validation of input data.",
              "code": "@Post()\n@UsePipes(new ValidationPipe())\ncreate(@Body() createCatDto: CreateCatDto) { ... }"
            }
          }
        ]
      },
      {
        "id": "nestjs-microservices",
        "title": "3. Microservice Fundamentals",
        "slides": [
          {
            "type": "topic-title",
            "title": "3. Distributed Power",
            "box": { "content": "Understanding transport layers and message patterns." }
          },
          {
            "type": "content",
            "title": "What is a Nest Microservice?",
            "box": {
              "content": "An application that uses a different transport layer than HTTP.",
              "list": [
                { "emoji": "📡", "text": "<strong>Transport:</strong> TCP, Redis, gRPC, RabbitMQ, MQTT, NATS." },
                { "emoji": "🏗️", "text": "<strong>ClientProxy:</strong> Used to communicate with external microservices." }
              ]
            }
          },
          {
            "type": "content",
            "title": "The gRPC Transport",
            "box": {
              "content": "High-performance, cross-language communication using Protocol Buffers.",
              "code": "options: {\n    package: 'hero',\n    protoPath: join(__dirname, 'hero/hero.proto'),\n}"
            }
          },
          {
            "type": "content",
            "title": "RabbitMQ & Messaging",
            "box": {
              "content": "Asynchronous communication using message brokers for decoupled systems.",
              "list": [
                { "emoji": "🐇", "text": "<strong>Reliable:</strong> Guaranteed delivery and message queuing." },
                { "emoji": "🧩", "text": "<strong>Scalable:</strong> Easily add more consumers to handle load." }
              ]
            }
          }
        ]
      },
      {
        "id": "nestjs-hybrid",
        "title": "4. Hybrid Applications",
        "slides": [
          {
            "type": "topic-title",
            "title": "4. The Best of Both Worlds",
            "box": { "content": "Combining HTTP and Microservice transport layers." }
          },
          {
            "type": "content",
            "title": "What is a Hybrid App?",
            "box": {
              "content": "An application that listens on multiple ports or uses multiple transport layers simultaneously.",
              "code": "const app = await NestFactory.create(AppModule);\nconst microservice = app.connectMicroservice({ ... });\nawait app.startAllMicroservices();\nawait app.listen(3000);"
            }
          },
          {
            "type": "content",
            "title": "Request-Response Pattern",
            "box": {
              "content": "Synchronous communication where the caller waits for a response.",
              "code": "@MessagePattern({ cmd: 'sum' })\naccumulate(data: number[]): number {\n    return (data || []).reduce((a, b) => a + b);\n}"
            }
          },
          {
            "type": "content",
            "title": "Event-based Pattern",
            "box": {
              "content": "Asynchronous communication for 'fire and forget' operations.",
              "code": "@EventPattern('user_created')\nasync handleUserCreated(data: Record<string, unknown>) {\n    // handle event\n}"
            }
          }
        ]
      },
      {
        "id": "nestjs-security-persistence",
        "title": "5. Security & Persistence",
        "slides": [
          {
            "type": "topic-title",
            "title": "5. Data and Protection",
            "box": { "content": "Mastering TypeORM, Prisma, and JWT." }
          },
          {
            "type": "content",
            "title": "ORM Integration",
            "box": {
              "content": "Nest provides official modules for TypeORM, Prisma, and Mongoose.",
              "code": "@Module({\n    imports: [TypeOrmModule.forRoot({ ... })],\n})"
            }
          },
          {
            "type": "content",
            "title": "Authentication with Passport",
            "box": {
              "content": "Using the @nestjs/passport and @nestjs/jwt modules for secure session management.",
              "code": "@UseGuards(JwtAuthGuard)\n@Get('profile')\ngetProfile(@Request() req) {\n    return req.user;\n}"
            }
          },
          {
            "type": "content",
            "title": "RBAC and Guards",
            "box": {
              "content": "Implementing Role-Based Access Control using custom decorators and guards.",
              "code": "@Roles(Role.Admin)\n@UseGuards(RolesGuard)"
            }
          }
        ]
      },
      {
        "id": "nestjs-observability",
        "title": "6. Observability",
        "slides": [
          {
            "type": "topic-title",
            "title": "6. Maintenance & Monitoring",
            "box": { "content": "Logging, health checks, and metrics." }
          },
          {
            "type": "content",
            "title": "OpenTelemetry Integration",
            "box": {
              "content": "Distributed tracing for microservices using OpenTelemetry and Jaeger.",
              "list": [
                { "emoji": "🕵️", "text": "<strong>Tracing:</strong> Track requests across service boundaries." },
                { "emoji": "📊", "text": "<strong>Visibility:</strong> Identify bottlenecks in complex distributed flows." }
              ]
            }
          },
          {
            "type": "content",
            "title": "Logger Integration",
            "box": {
              "content": "Using the built-in Logger class or integrating Pino for high-performance logging.",
              "code": "private readonly logger = new Logger(MyService.name);"
            }
          },
          {
            "type": "content",
            "title": "Terminus Health Checks",
            "box": {
              "content": "Providing endpoints for Kubernetes liveness and readiness probes.",
              "code": "@Get('health')\n@HealthCheck()\ncheck() {\n    return this.health.check([ ... ]);\n}"
            }
          },
          {
            "type": "content",
            "title": "Custom Health Indicators",
            "box": {
              "content": "Creating custom checks for external dependencies like third-party APIs.",
              "code": "export class MyHealthIndicator extends HealthIndicator { ... }"
            }
          }
        ]
      },
      {
        "id": "nestjs-testing",
        "title": "7. Testing Enterprise Apps",
        "slides": [
          {
            "type": "topic-title",
            "title": "7. Quality First",
            "box": { "content": "Unit, Integration, and E2E testing with Jest." }
          },
          {
            "type": "content",
            "title": "The Testing Module",
            "box": {
              "content": "Using Test.createTestingModule() to mock dependencies and isolate tests.",
              "code": "const module: TestingModule = await Test.createTestingModule({ ... }).compile();"
            }
          },
          {
            "type": "content",
            "title": "E2E Testing",
            "box": {
              "content": "Testing the full request-response cycle using SuperTest.",
              "code": "return request(app.getHttpServer()).get('/cats').expect(200);"
            }
          }
        ]
      },
      {
        "id": "nestjs-deployment",
        "title": "8. Enterprise Deployment",
        "slides": [
          {
            "type": "topic-title",
            "title": "8. Scaling in Production",
            "box": { "content": "Docker, Kubernetes, and Serverless." }
          },
          {
            "type": "content",
            "title": "Multi-stage Docker Builds",
            "box": {
              "content": "Creating lean production images by separating build and runtime environments.",
              "list": [
                { "emoji": "🐳", "text": "<strong>Small:</strong> Drastically reduce image size." },
                { "emoji": "🔒", "text": "<strong>Secure:</strong> Only include production dependencies." }
              ]
            }
          },
          {
            "type": "content",
            "title": "Kubernetes Orchestration",
            "box": {
              "content": "Deploying NestJS microservices as stateless pods in a K8s cluster.",
              "list": [
                { "emoji": "☸️", "text": "<strong>Self-healing:</strong> Auto-restart failed containers." },
                { "emoji": "⚖️", "text": "<strong>Auto-scaling:</strong> Scale based on CPU/Memory usage." }
              ]
            }
          }
        ]
      },
