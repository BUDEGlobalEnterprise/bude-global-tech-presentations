      {
        "id": "nestjs-foundations",
        "title": "1. NestJS Foundations",
        "slides": [
          {
            "type": "topic-title",
            "title": "1. Solid Grounding",
            "subtitle": "The philosophy and core concepts of NestJS."
          },
          {
            "type": "content",
            "title": "What is NestJS?",
            "box": {
              "list": [
                {
                  "emoji": "📜",
                  "text": "<strong>TypeScript:</strong> Built with and for TypeScript."
                },
                {
                  "emoji": "🧩",
                  "text": "<strong>Modular:</strong> Encourages encapsulation and separation of concerns."
                }
              ],
              "title": "Nest is built on top of Express or Fastify, providing an out-of-the-box application architecture."
            }
          },
          {
            "type": "content",
            "title": "Dependency Injection (DI)",
            "box": {
              "code": "@Injectable()\nexport class UsersService { ... }",
              "title": "A core architectural pattern for managing object creation and lifecycle."
            }
          },
          {
            "type": "content",
            "title": "Decorators",
            "box": {
              "code": "@Controller('users')\nexport class UsersController { ... }",
              "title": "Using TypeScript decorators for clean, declarative meta-programming."
            }
          },
          {
            "type": "content",
            "title": "The Modular System",
            "box": {
              "code": "@Module({\n    controllers: [UsersController],\n    providers: [UsersService],\n})\nexport class UsersModule {}",
              "title": "Every Nest application has at least one module (the root module)."
            }
          }
        ]
      },
      {
        "id": "nestjs-architecture",
        "title": "2. Architecture Patterns",
        "slides": [
          {
            "type": "topic-title",
            "title": "2. Inside the Box",
            "subtitle": "Mastering Controllers, Providers, and Pipes."
          },
          {
            "type": "content",
            "title": "Controllers",
            "box": {
              "code": "@Get()\nfindAll(@Query() query: ListAllEntities) {\n    return `This action returns all cats (limit: ${query.limit} items)`;\n}",
              "title": "Responsible for handling incoming requests and returning responses to the client."
            }
          },
          {
            "type": "content",
            "title": "Providers",
            "box": {
              "list": [
                {
                  "emoji": "💉",
                  "text": "<strong>Injected:</strong> Can be injected into other classes via constructors."
                },
                {
                  "emoji": "🔄",
                  "text": "<strong>Lifecycle:</strong> Managed by the Nest IoC container."
                }
              ],
              "title": "Almost everything in Nest is a provider: services, repositories, factories, helpers, etc."
            }
          },
          {
            "type": "content",
            "title": "Pipes & Validation",
            "box": {
              "code": "@Post()\n@UsePipes(new ValidationPipe())\ncreate(@Body() createCatDto: CreateCatDto) { ... }",
              "title": "Use pipes for transformation and validation of input data."
            }
          }
        ]
      },
      {
        "id": "nestjs-microservices",
        "title": "3. Microservice Fundamentals",
        "slides": [
          {
            "type": "topic-title",
            "title": "3. Distributed Power",
            "subtitle": "Understanding transport layers and message patterns."
          },
          {
            "type": "content",
            "title": "What is a Nest Microservice?",
            "box": {
              "list": [
                {
                  "emoji": "📡",
                  "text": "<strong>Transport:</strong> TCP, Redis, gRPC, RabbitMQ, MQTT, NATS."
                },
                {
                  "emoji": "🏗️",
                  "text": "<strong>ClientProxy:</strong> Used to communicate with external microservices."
                }
              ],
              "title": "An application that uses a different transport layer than HTTP."
            }
          },
          {
            "type": "content",
            "title": "The gRPC Transport",
            "box": {
              "code": "options: {\n    package: 'hero',\n    protoPath: join(__dirname, 'hero/hero.proto'),\n}",
              "title": "High-performance, cross-language communication using Protocol Buffers."
            }
          },
          {
            "type": "content",
            "title": "RabbitMQ & Messaging",
            "box": {
              "list": [
                {
                  "emoji": "🐇",
                  "text": "<strong>Reliable:</strong> Guaranteed delivery and message queuing."
                },
                {
                  "emoji": "🧩",
                  "text": "<strong>Scalable:</strong> Easily add more consumers to handle load."
                }
              ],
              "title": "Asynchronous communication using message brokers for decoupled systems."
            }
          }
        ]
      },
      {
        "id": "nestjs-hybrid",
        "title": "4. Hybrid Applications",
        "slides": [
          {
            "type": "topic-title",
            "title": "4. The Best of Both Worlds",
            "subtitle": "Combining HTTP and Microservice transport layers."
          },
          {
            "type": "content",
            "title": "What is a Hybrid App?",
            "box": {
              "code": "const app = await NestFactory.create(AppModule);\nconst microservice = app.connectMicroservice({ ... });\nawait app.startAllMicroservices();\nawait app.listen(3000);",
              "title": "An application that listens on multiple ports or uses multiple transport layers simultaneously."
            }
          },
          {
            "type": "content",
            "title": "Request-Response Pattern",
            "box": {
              "code": "@MessagePattern({ cmd: 'sum' })\naccumulate(data: number[]): number {\n    return (data || []).reduce((a, b) => a + b);\n}",
              "title": "Synchronous communication where the caller waits for a response."
            }
          },
          {
            "type": "content",
            "title": "Event-based Pattern",
            "box": {
              "code": "@EventPattern('user_created')\nasync handleUserCreated(data: Record<string, unknown>) {\n    // handle event\n}",
              "title": "Asynchronous communication for 'fire and forget' operations."
            }
          }
        ]
      },
