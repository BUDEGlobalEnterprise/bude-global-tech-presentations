      {
        "id": "nestjs-advanced-features",
        "title": "9. Advanced NestJS Features",
        "slides": [
          {
            "type": "topic-title",
            "title": "9. Beyond the Basics",
            "box": { "content": "Mastering Interceptors, Filters, and Middlewares." }
          },
          {
            "type": "content",
            "title": "Interceptors",
            "box": {
              "content": "Bind extra logic before or after method execution, transform results, or wrap functions.",
              "code": "@Injectable()\nexport class TransformInterceptor implements NestInterceptor { ... }"
            }
          },
          {
            "type": "content",
            "title": "Exception Filters",
            "box": {
              "content": "Responsible for processing all unhandled exceptions across an application.",
              "code": "@Catch(HttpException)\nexport class HttpErrorFilter implements ExceptionFilter { ... }"
            }
          },
          {
            "type": "content",
            "title": "Middlewares",
            "box": {
              "content": "Functions called before the route handler, perfect for logging or request manipulation.",
              "code": "export function logger(req: Request, res: Response, next: NextFunction) { ... }"
            }
          }
        ]
      },
      {
        "id": "nestjs-dynamic-modules",
        "title": "10. Dynamic Modules",
        "slides": [
          {
            "type": "topic-title",
            "title": "10. Scalable Configuration",
            "box": { "content": "Creating flexible, configurable modules." }
          },
          {
            "type": "content",
            "title": "What are Dynamic Modules?",
            "box": {
              "content": "Modules that can be configured dynamically at runtime.",
              "code": "static register(options: ConfigOptions): DynamicModule { ... }"
            }
          },
          {
            "type": "content",
            "title": "The ConfigModule Pattern",
            "box": {
              "content": "Using the official ConfigModule for managing application environment variables.",
              "code": "ConfigModule.forRoot({ isGlobal: true })"
            }
          },
          {
            "type": "content",
            "title": "Custom Providers",
            "box": {
              "content": "Defining your own providers using useValue, useClass, or useFactory.",
              "code": "{\n    provide: 'CONNECTION',\n    useValue: connection,\n}"
            }
          }
        ]
