          }
        ]
      },
      {
        "id": "philosophy",
        "title": "1. The Laravel Philosophy",
        "slides": [
          {
            "type": "topic-title",
            "title": "1. Philosophy",
            "box": { "content": "Developer Happiness (DX) is at the core of every design decision." }
          },
          {
            "type": "content",
            "title": "What is Laravel?",
            "box": {
              "content": "A web application framework with expressive, elegant syntax. It takes the pain out of development by easing common tasks.",
              "list": [
                { "emoji": "🎨", "text": "<strong>Expressive:</strong> Code that reads like prose." },
                { "emoji": "🛠️", "text": "<strong>Opinionated:</strong> Provides a sensible, powerful default for everything." },
                { "emoji": "🚀", "text": "<strong>Fast-paced:</strong> Rapid prototyping to production-ready in record time." }
              ]
            }
          },
          {
            "type": "content",
            "title": "The Artisan CLI",
            "box": {
              "content": "Laravel's powerful command-line interface based on Symfony Console.",
              "code": "# shell: php artisan list\n# shell: php artisan make:controller UserController\n# shell: php artisan migrate"
            }
          },
          {
            "type": "content",
            "title": "The Ecosystem",
            "box": {
              "content": "Laravel isn't just a framework; it's a massive, cohesive ecosystem.",
              "list": [
                { "emoji": "📦", "text": "<strong>Composer:</strong> Dependency management for PHP." },
                { "emoji": "🔧", "text": "<strong>Forge/Vapor:</strong> Painless server and serverless deployment." },
                { "emoji": "🛡️", "text": "<strong>Sanctum/Passport:</strong> Robust authentication solutions." }
              ]
            }
          }
        ]
      },
      {
        "id": "architecture",
        "title": "2. Core Architecture",
        "slides": [
          {
            "type": "topic-title",
            "title": "2. Architecture",
            "box": { "content": "The Service Container is the heart of Laravel." }
          },
          {
            "type": "content",
            "title": "The Service Container",
            "box": {
              "content": "A powerful tool for managing class dependencies and performing dependency injection.",
              "code": "$this->app->bind('HelpSpot\\API', function ($app) {\n    return new HelpSpot\\API($app->make('HttpClient'));\n});"
            }
          },
          {
            "type": "content",
            "title": "Service Providers",
            "box": {
              "content": "The central place to configure and bootstrap all Laravel applications.",
              "list": [
                { "emoji": "🏗️", "text": "<strong>Register:</strong> Bind things into the service container." },
                { "emoji": "🚦", "text": "<strong>Boot:</strong> Kick off logic once all services are registered." }
              ]
            }
          },
          {
            "type": "content",
            "title": "The Facade Pattern",
            "box": {
              "content": "Facades provide a 'static' interface to classes that are available in the application's service container.",
              "code": "use Illuminate\\Support\\Facades\\Cache;\n\n$value = Cache::get('key');"
            }
          }
        ]
      },
      {
        "id": "eloquent-orm",
        "title": "3. Eloquent ORM",
        "slides": [
          {
            "type": "topic-title",
            "title": "3. Eloquent ORM",
            "box": { "content": "The most expressive ORM in the PHP ecosystem." }
          },
          {
            "type": "content",
            "title": "Active Record Implementation",
            "box": {
              "content": "Eloquent's Active Record implementation makes interacting with your database intuitive.",
              "code": "$user = User::where('email', 'alice@example.com')->first();\n$user->name = 'Alice Smith';\n$user->save();"
            }
          },
          {
            "type": "content",
            "title": "Expressive Relationships",
            "box": {
              "content": "Define relationships using simple method calls.",
              "code": "class Post extends Model {\n    public function comments() {\n        return $this->hasMany(Comment::class);\n    }\n}\n\n$comments = Post::find(1)->comments;"
            }
          },
          {
            "type": "content",
            "title": "Eloquent Collections",
            "box": {
              "content": "Every multi-result set returned by Eloquent is a Collection instance, providing dozens of helper methods.",
              "code": "$users = User::all();\n$names = $users->reject(fn($user) => $user->active)\n               ->map(fn($user) => $user->name);"
            }
          }
        ]
      },
      {
        "id": "routing-controllers",
        "title": "4. Routing & Controllers",
        "slides": [
          {
            "type": "topic-title",
            "title": "4. Routing",
            "box": { "content": "Defining the entry points to your application." }
          },
          {
            "type": "content",
            "title": "Expressive Routing",
            "box": {
              "content": "Routes are defined in the <code>routes/web.php</code> or <code>routes/api.php</code> files.",
              "code": "Route::get('/user/{id}', [UserController::class, 'show']);\n\nRoute::middleware(['auth'])->group(function () {\n    Route::get('/profile', [ProfileController::class, 'edit']);\n});"
            }
          },
          {
            "type": "content",
            "title": "Dependency Injection in Controllers",
            "box": {
              "content": "Laravel automatically injects dependencies into your controller methods.",
              "code": "public function store(Request $request, UserRepository $users) {\n    $users->create($request->all());\n    return redirect('/home');\n}"
            }
          },
          {
            "type": "content",
            "title": "Resource Controllers",
            "box": {
              "content": "Quickly create controllers that handle all CRUD operations.",
              "code": "# shell: php artisan make:controller PhotoController --resource\n\nRoute::resource('photos', PhotoController::class);"
            }
          }
        ]
      },
      {
        "id": "security-auth",
        "title": "5. Security & Authentication",
        "slides": [
          {
            "type": "topic-title",
            "title": "5. Security",
            "box": { "content": "Granular permissions and robust authentication." }
          },
          {
            "type": "content",
            "title": "Authentication Guards",
            "box": {
              "content": "Laravel supports multiple authentication 'guards', allowing you to authenticate against different user tables or token systems.",
              "code": "Auth::guard('api')->user();"
            }
          },
          {
            "type": "content",
            "title": "Gates & Policies",
            "box": {
              "content": "Authorization logic simplified. Use Gates for simple checks and Policies for model-specific logic.",
              "code": "Gate::define('update-post', function (User $user, Post $post) {\n    return $user->id === $post->user_id;\n});\n\n$this->authorize('update', $post);"
            }
          },
          {
            "type": "content",
            "title": "Laravel Sanctum",
            "box": {
              "content": "A featherweight authentication system for SPAs and simple APIs using mobile tokens or session cookies.",
              "code": "$user->createToken('token-name')->plainTextToken;"
            }
          }
        ]
      },
      {
        "id": "modern-frontend",
        "title": "6. Modern Frontend",
        "slides": [
          {
            "type": "topic-title",
            "title": "6. Frontend",
            "box": { "content": "Blade, Livewire, and the TALL stack." }
          },
          {
            "type": "content",
            "title": "Blade Templating",
            "box": {
              "content": "The powerful, aesthetic templating engine for Laravel.",
              "code": "@if ($user->isActive())\n    Welcome, {{ $user->name }}!\n@endif\n\n<x-alert type=\"error\" :message=\"$message\" />"
            }
          },
          {
            "type": "content",
            "title": "Laravel Livewire",
            "box": {
              "content": "Build dynamic interfaces using PHP. No complex JavaScript frameworks required.",
              "code": "class Counter extends Component {\n    public $count = 0;\n    public function increment() { $this->count++; }\n}"
            }
          },
          {
            "type": "content",
            "title": "The TALL Stack",
            "box": {
              "content": "The modern developer's choice for rapid, interactive Laravel applications.",
              "list": [
                { "emoji": "🎨", "text": "<strong>Tailwind CSS:</strong> Utility-first styling." },
                { "emoji": "🏔️", "text": "<strong>Alpine.js:</strong> Lightweight UI reactivity." },
                { "emoji": "⚡", "text": "<strong>Livewire:</strong> Full-stack reactivity in PHP." },
                { "emoji": "🏮", "text": "<strong>Laravel:</strong> The rock-solid foundation." }
              ]
            }
          }
        ]
      },
      {
        "id": "logic-validation",
        "title": "7. Logic & Flow",
        "slides": [
          {
            "type": "topic-title",
            "title": "7. Logic & Flow",
            "box": { "content": "Clean code with Form Requests and Middlewares." }
          },
          {
            "type": "content",
            "title": "Form Request Validation",
            "box": {
              "content": "Keep your controllers clean by offloading validation logic to dedicated Form Request classes.",
              "code": "public function rules() {\n    return [\n        'title' => 'required|unique:posts|max:255',\n        'body' => 'required',\n    ];\n}"
            }
          },
          {
            "type": "content",
            "title": "Validation Rules (Elite)",
            "box": {
              "content": "Laravel includes over 90 validation rules out of the box, plus the ability to create custom ones.",
              "list": [
                { "emoji": "📧", "text": "<code>email:rfc,dns</code> - Advanced email validation." },
                { "emoji": "🛡️", "text": "<code>prohibited_if</code> - Conditional logic for complex forms." },
                { "emoji": "🎨", "text": "<code>Rule::unique()</code> - Fluent rule builder." }
              ]
            }
          },
          {
            "type": "content",
            "title": "Custom Middlewares",
            "box": {
              "content": "Middlewares provide a convenient mechanism for inspecting and filtering HTTP requests entering your application.",
              "code": "public function handle($request, Closure $next) {\n    if ($request->age <= 200) {\n        return redirect('home');\n    }\n    return $next($request);\n}"
            }
          }
        ]
      },
      {
        "id": "real-time-queues",
        "title": "8. Real-time & Queues",
        "slides": [
          {
            "type": "topic-title",
            "title": "8. Real-time",
            "box": { "content": "Queues, Redis, and WebSockets." }
          },
          {
            "type": "content",
            "title": "The Unified Queue API",
            "box": {
              "content": "Offload heavy tasks to the background effortlessly. Supports Redis, Database, Amazon SQS, and more.",
              "code": "ProcessPodcast::dispatch($podcast)->onQueue('emails');"
            }
          },
          {
            "type": "content",
            "title": "Laravel Horizon",
            "box": {
              "content": "A beautiful dashboard and code-driven configuration for your Redis-powered Laravel queues.",
              "list": [
                { "emoji": "📊", "text": "<strong>Monitoring:</strong> Real-time throughput and error tracking." },
                { "emoji": "🚦", "text": "<strong>Auto-scaling:</strong> Scalable based on queue workload." }
              ]
            }
          },
          {
            "type": "content",
            "title": "Laravel Reverb",
            "box": {
              "content": "The first-party, high-speed WebSocket server built specifically for Laravel applications.",
              "code": "# shell: php artisan reverb:start"
            }
          }
        ]
      },
      {
        "id": "advanced-features",
        "title": "9. Advanced Features",
        "slides": [
          {
            "type": "topic-title",
            "title": "9. Advanced Features",
            "box": { "content": "Events, Observers, and Collections." }
          },
          {
            "type": "content",
            "title": "Events & Listeners",
            "box": {
              "content": "Decouple your application logic by using Laravel's event system.",
              "code": "OrderShipped::dispatch($order);\n\n// In EventServiceProvider\n'OrderShipped' => [\n    'SendShipmentNotification',\n]"
            }
          },
          {
            "type": "content",
            "title": "Eloquent Observers",
            "box": {
              "content": "Group all of your Eloquent listeners into a single class.",
              "code": "class UserObserver {\n    public function created(User $user) {\n        // Logic after user creation\n    }\n}"
            }
          },
          {
            "type": "content",
            "title": "Macroable Classes",
            "box": {
              "content": "Many of Laravel's core classes are 'macroable', allowing you to add custom methods at runtime.",
              "code": "Response::macro('caps', function ($value) {\n    return Response::make(strtoupper($value));\n});"
            }
          }
        ]
      },
      {
        "id": "testing-laravel",
        "title": "10. Testing",
        "slides": [
          {
            "type": "topic-title",
            "title": "10. Testing",
            "box": { "content": "Pest and PHPUnit integration." }
          },
          {
            "type": "content",
            "title": "Pest PHP",
            "box": {
              "content": "The elegant PHP testing framework that makes writing tests a joy.",
              "code": "it('has a welcome page', function () {\n    get('/')->assertStatus(200);\n});"
            }
          },
          {
            "type": "content",
            "title": "Feature Testing",
            "box": {
              "content": "Test the entire HTTP request lifecycle from end-to-end.",
              "code": "$response = $this->post('/login', [\n    'email' => 'alice@example.com',\n    'password' => 'password',\n]);\n$response->assertRedirect('/home');"
            }
          },
          {
            "type": "content",
            "title": "Mocking Dependencies",
            "box": {
              "content": "Easily mock external services using Laravel's built-in mocking utilities.",
              "code": "Http::fake([\n    'google.com/*' => Http::response('Hello World', 200),\n]);"
            }
          }
        ]
      },
      {
        "id": "production-optimization",
        "title": "11. Production & Optimization",
        "slides": [
          {
            "type": "topic-title",
            "title": "11. Production",
            "box": { "content": "Squeezing every drop of performance." }
          },
          {
            "type": "content",
            "title": "Config & Route Caching",
            "box": {
              "content": "In production, you should cache your configuration and routes to significantly reduce bootstrap time.",
              "code": "# shell: php artisan config:cache\n# shell: php artisan route:cache"
            }
          },
          {
            "type": "content",
            "title": "Asset Compiling (Vite)",
            "box": {
              "content": "Laravel uses Vite for lightning-fast asset bundling and HMR.",
              "code": "# shell: npm run build"
            }
          },
          {
            "type": "content",
            "title": "Optimizing Floquent",
            "box": {
              "content": "Avoid the N+1 problem by using eager loading.",
              "code": "$books = Book::with('author')->get();"
            }
          }
        ]
      },
