      },
      {
        "id": "graph-foundations",
        "title": "1. Graph Foundations",
        "slides": [
          {
            "type": "topic-title",
            "title": "1. Why Graphs?",
            "box": { "content": "The world is connected, not just tabular." }
          },
          {
            "type": "content",
            "title": "Relation-First Design",
            "box": {
              "content": "Unlike Relational DBs, relationships are first-class citizens in Neo4j.",
              "list": [
                { "emoji": "🕸️", "text": "<strong>Native Graph Processing:</strong> No JOINs; use pointers to traverse neighbors." },
                { "emoji": "⚡", "text": "<strong>Index-Free Adjacency:</strong> Constant time traversal regardless of total data size." }
              ]
            }
          }
        ]
      },
      {
        "id": "labeled-property-graph",
        "title": "2. The Labeled Property Graph (LPG)",
        "slides": [
          {
            "type": "topic-title",
            "title": "2. The LPG Model",
            "box": { "content": "Nodes, Relationships, and Properties." }
          },
          {
            "type": "content",
            "title": "Core Components",
            "box": {
              "list": [
                { "emoji": "🔵", "text": "<strong>Nodes:</strong> Represent entities (e.g., User, Product)." },
                { "emoji": "➡️", "text": "<strong>Relationships:</strong> Connect nodes with direction and type (e.g., LIKES, BOUGHT)." },
                { "emoji": "🏷️", "text": "<strong>Labels:</strong> Categorize nodes." },
                { "emoji": "📝", "text": "<strong>Properties:</strong> Key-value pairs on both nodes and relationships." }
              ]
            }
          }
        ]
      },
      {
        "id": "cypher-query-language",
        "title": "3. Cypher Query Language",
        "slides": [
          {
            "type": "topic-title",
            "title": "3. Cypher",
            "box": { "content": "ASCII art for patterns." }
          },
          {
            "type": "content",
            "title": "Pattern Matching",
            "box": {
              "content": "A declarative approach to graph querying.",
              "code": "MATCH (u:User)-[:FOLLOWS]->(m:User)\nWHERE u.name = 'Alice'\nRETURN m.name"
            }
          },
          {
            "type": "content",
            "title": "The MERGE Clause",
            "box": {
              "content": "The 'Get or Create' pattern.",
              "list": [
                { "emoji": "🔗", "text": "<strong>Safety:</strong> Ensures unique nodes and relationships without duplicates." }
              ]
            }
          },
          {
            "type": "content",
            "title": "Variable Length Paths",
            "box": {
              "content": "Querying connections of arbitrary depth.",
              "code": "MATCH (u:User)-[:FOLLOWS*1..3]->(f:User)\nRETURN f"
            }
          }
        ]
      },
      {
        "id": "traversal-internals",
        "title": "4. Traversal Internals",
        "slides": [
          {
            "type": "topic-title",
            "title": "4. How Traversal Works",
            "box": { "content": "Pointers and adjacency." }
          },
          {
            "type": "content",
            "title": "Index-Free Adjacency",
            "box": {
              "content": "Storing pointers to neighbors directly on the node record.",
              "list": [
                { "emoji": "🏎️", "text": "<strong>Speed:</strong> O(1) jump to the next node; no lookups required." }
              ]
            }
          },
          {
            "type": "content",
            "title": "Query Execution Plan",
            "box": {
              "content": "Interpreting Cypher into traversals.",
              "list": [
                { "emoji": "🗺️", "text": "<strong>Planner:</strong> Determines the best starting point (Entry Node) using indexes." },
                { "emoji": "🕹️", "text": "<strong>Expander:</strong> Iterates over relationship pointers." }
              ]
            }
          }
        ]
      },
      {
        "id": "data-modeling-patterns",
        "title": "5. Graph Data Modeling",
        "slides": [
          {
            "type": "topic-title",
            "title": "5. Modeling Patterns",
            "box": { "content": "Nodes vs. Relationships." }
          },
          {
            "type": "content",
            "title": "Entity vs Relationship",
            "box": {
              "content": "When to use a node vs a relationship property.",
              "list": [
                { "emoji": "🔵", "text": "<strong>Node:</strong> For things that exist independently." },
                { "emoji": "➡️", "text": "<strong>Relationship:</strong> For the context of the connection (e.g., timestamp, weight)." }
              ]
            }
          },
          {
            "type": "content",
            "title": "Anti-Patterns",
            "box": {
              "content": "Common pitfalls in graph design.",
              "list": [
                { "emoji": "🚫", "text": "<strong>Dense Nodes:</strong> Nodes with millions of relationships (Hotspots)." }
              ]
            }
          }
        ]
      },
      {
        "id": "graph-algorithms-gds",
        "title": "6. Graph Data Science (GDS)",
        "slides": [
          {
            "type": "topic-title",
            "title": "6. Graph Algorithms",
            "box": { "content": "The science of connectivity." }
          },
          {
            "type": "content",
            "title": "Centrality: Who is Important?",
            "box": {
              "list": [
                { "emoji": "👑", "text": "<strong>PageRank:</strong> Google's original influence algorithm." },
                { "emoji": "📍", "text": "<strong>Betweenness:</strong> Finding bottlenecks and bridge nodes." },
                { "emoji": "🔗", "text": "<strong>Closeness:</strong> Identifying the best-placed brokers." }
              ]
            }
          },
          {
            "type": "content",
            "title": "Community: Who Belongs Together?",
            "box": {
              "list": [
                { "emoji": "👥", "text": "<strong>Louvain:</strong> Detecting clusters and modularity." },
                { "emoji": "🧬", "text": "<strong>Label Propagation:</strong> Fast community detection based on neighbor labels." }
              ]
            }
          },
          {
            "type": "content",
            "title": "Similarity: Who is Like You?",
            "box": {
              "list": [
                { "emoji": "👯", "text": "<strong>Jaccard Similarity:</strong> Intersection over union of neighbors." },
                { "emoji": "📐", "text": "<strong>Cosine Similarity:</strong> Comparing vector representations of nodes." }
              ]
            }
          },
          {
            "type": "content",
            "title": "Pathfinding: How Do I Get There?",
            "box": {
              "list": [
                { "emoji": "🗺️", "text": "<strong>A*:</strong> Heuristic path search." },
                { "emoji": "🕵️", "text": "<strong>BFS / DFS:</strong> Foundational search strategies." }
              ]
            }
          }
        ]
      },
