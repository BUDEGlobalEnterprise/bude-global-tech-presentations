          {
            "type": "content",
            "title": "Connection Management: WebSockets & Gateway",
            "box": {
              "title": "Technical Details",
              "list": [
                "<strong>Chat Service</strong>: Manages persistent WebSocket connections with clients",
                "<strong>Presence Service</strong>: Tracks user online/offline status via heartbeats",
                "<strong>Message Service</strong>: Handles message storage and retrieval for offline users",
                "<strong>Push Notification Service</strong>: Alerts offline users (Apple APNs / Google FCM)"
              ]
            },
            "note": null
          },
          {
            "type": "content",
            "title": "Message Delivery Flow",
            "box": {
              "title": "Technical Details",
              "list": [
                "1. User A sends message to Chat Server via WebSocket",
                "2. Chat Server stores message in DB (Delivery status: Sent)",
                "3. Chat Server asks Connection Map: 'Where is User B?'",
                "4a. If User B is Online: Forward message to User B's Chat Server",
                "4b. If User B is Offline: Send Push Notification via APNs/FCM",
                "5. User B acknowledges: Send 'Delivered' receipt back to User A",
                "<strong>type</strong>: NoSQL Wide-column (Cassandra/HBase)",
                "<strong>reason</strong>: Sequential writes are very fast, handling millions of small messages/sec, easy to partition by conversation_id"
              ]
            },
            "note": null
          },
          {
            "type": "content",
            "title": "Presence Service: Are you there?",
            "box": {
              "title": "Technical Details",
              "list": [
                "<strong>heartbeat</strong>: Client sends 'I am here' ping every 30s to Redis/Keep-alive store",
                "<strong>timeout</strong>: If no ping for 1 min, mark as Offline",
                "<strong>fan_out</strong>: When status changes, push update to all friends' chat screens"
              ]
            },
            "note": null
          },
          {
            "type": "content",
            "title": "Encryption & Security (Signal Protocol)",
