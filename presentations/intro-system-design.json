      {
        "id": "module_13",
        "title": "Module 13: Case Study - WhatsApp Real-time Messaging",
        "slides": [
          {
            "type": "content",
            "title": "Real-time Messaging: Requirements",
            "box": {
              "title": "Key Concepts",
              "list": []
