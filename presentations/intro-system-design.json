        "id": "module_1",
        "title": "Module 1: Foundations of Scalable Systems",
        "slides": [
          {
            "type": "content",
            "title": "The Three Pillars of System Design",
            "subtitle": "Reliability, Scalability, Maintainability in the Age of Cloud",
            "box": {
              "title": "The Three Pillars",
              "list": [
                "<strong>Reliability</strong>: System continues to work correctly despite faults",
                "<strong>Scalability</strong>: System can handle growth in load without degradation",
                "<strong>Maintainability</strong>: System can be operated, maintained, and evolved efficiently"
              ]
            },
            "note": {
              "text": "Reliability, Scalability, and Maintainability are fundamental."
            }
          },
          {
            "type": "content",
            "title": "Understanding Load: From Request Patterns to Data Volumes",
            "box": {
              "title": "Load Characteristics",
              "list": [
                "<strong>Read-Heavy</strong>: 100:1 to 1000:1 (Social media feeds, News websites, Product catalogs)",
                "<strong>Write-Heavy</strong>: 1:100 to 1:1000 (IoT sensor data, Log aggregation, Financial transactions)",
                "<strong>Mixed Workload</strong>: 10:1 to 1:10 (E-commerce, SaaS applications, Collaboration tools)"
              ]
            }
          },
          {
            "type": "content",
            "title": "Design Principles: From Theory to Practice",
            "box": {
              "title": "Core Design Principles",
              "list": [
                "<strong>Simplicity</strong>: The simplest solution that meets requirements",
                "<strong>Loose Coupling</strong>: Components interact through well-defined interfaces",
                "<strong>Idempotency</strong>: Operations can be applied multiple times without changing result",
                "<strong>Graceful Degradation</strong>: System maintains partial functionality during failures"
              ]
            }
          },
          {
            "type": "quiz",
            "question": "What does 99.99% availability mean in minutes of downtime per year?",
            "options": [
              "8.76 hours",
              "52.56 minutes",
              "5.26 minutes",
              "31.5 seconds"
            ],
            "correctAnswer": 1,
            "explanation": "99.99% availability = 0.01% downtime = 0.0001 * 525,600 minutes/year = 52.56 minutes"
          },
          {
            "type": "quiz",
            "question": "Which pillar focuses on reducing operational complexity?",
            "options": [
              "Reliability",
              "Scalability",
              "Maintainability",
              "All of them"
            ],
            "correctAnswer": 2,
            "explanation": "Maintainability includes operability (ease of operation) and simplicity (reduced complexity)"
          },
          {
            "type": "quiz",
            "question": "What does p99 latency represent?",
            "options": [
              "Average latency",
              "Median latency",
              "99th percentile latency",
              "Worst-case latency"
            ],
            "correctAnswer": 2,
            "explanation": "p99 means 99% of requests are faster than this value. It captures tail latency."
          }
        ]
