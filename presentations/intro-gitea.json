            "type": "content",
            "emoji": "🆚",
            "title": "Gitea vs GitHub vs GitLab",
            "box": {
              "list": [
                {
                  "emoji": "🏠",
                  "text": "<strong>Gitea</strong> - Self-hosted, lightweight, minimal resources"
                },
                {
                  "emoji": "🌐",
                  "text": "<strong>GitHub</strong> - Cloud, massive ecosystem, Microsoft-owned"
                },
                {
                  "emoji": "🏢",
                  "text": "<strong>GitLab</strong> - Self-hosted/cloud, feature-rich, heavier"
                },
                {
                  "emoji": "🔓",
                  "text": "<strong>Gitea</strong> - No vendor lock-in, full control"
                },
                {
                  "emoji": "💰",
                  "text": "<strong>Gitea</strong> - Completely free, no enterprise pricing"
                },
                {
                  "emoji": "⚡",
                  "text": "<strong>Gitea</strong> - Faster startup, lower memory footprint"
                }
              ]
            }
          },
          {
            "type": "content",
            "emoji": "🔄",
            "title": "Gitea vs Gogs",
            "box": {
              "list": [
                {
                  "emoji": "👥",
                  "text": "<strong>Gitea</strong> - Community-driven fork"
                },
                {
                  "emoji": "👤",
                  "text": "<strong>Gogs</strong> - Single maintainer original"
                },
                {
                  "emoji": "🚀",
                  "text": "<strong>Gitea</strong> - More active development"
                },
                {
                  "emoji": "🔧",
                  "text": "<strong>Gitea</strong> - More features and integrations"
                },
