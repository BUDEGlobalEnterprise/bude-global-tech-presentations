      {
        "id": "installation",
        "title": "Installation & Setup",
        "slides": [
          {
            "type": "topic-title",
            "title": "Getting Started with Gitea"
          },
          {
            "type": "content",
            "emoji": "📦",
            "title": "Installation Methods",
            "box": {
              "list": [
                {
                  "emoji": "⚡",
                  "text": "<strong>Binary File</strong> - Direct download and run"
                },
                {
                  "emoji": "🐳",
                  "text": "<strong>Docker Container</strong> - Containerized deployment"
                },
                {
                  "emoji": "☸️",
                  "text": "<strong>Kubernetes Helm</strong> - Cloud-native deployment"
                },
                {
                  "emoji": "📚",
                  "text": "<strong>Package Managers</strong> - apt, yum, brew"
                },
                {
                  "emoji": "🔧",
                  "text": "<strong>Source Build</strong> - From Go source code"
                }
              ]
            }
          },
          {
            "type": "content",
            "emoji": "🐳",
            "title": "Docker Installation",
            "box": {
              "code": "# Create volume for data\ndocker volume create gitea-data\n\n# Run Gitea container\ndocker run -d \\\n  --name gitea \\\n  -p 3000:3000 \\\n  -p 222:22 \\\n  -v gitea-data:/data \\\n  -v /etc/timezone:/etc/timezone:ro \\\n  -v /etc/localtime:/etc/localtime:ro \\\n  gitea/gitea:latest\n\n# Access at http://localhost:3000",
              "title": "<strong>Quick start with Docker</strong>"
            }
          },
          {
            "type": "content",
            "emoji": "⚡",
            "title": "Binary Installation",
            "box": {
              "code": "# Download latest binary\nwget -O gitea https://dl.gitea.com/gitea/1.20.0/gitea-1.20.0-linux-amd64\nchmod +x gitea\n\n# Create user and directories\nsudo useradd \\\n  --system \\\n  --shell /bin/bash \\\n  --comment 'Gitea' \\\n  --create-home \\\n  --home-dir /home/gitea \\\n  gitea\n\n# Run Gitea\n./gitea web",
              "title": "<strong>Direct binary execution</strong>"
            }
          }
        ]
      },
      {
        "id": "configuration",
        "title": "Configuration",
        "slides": [
          {
            "type": "topic-title",
            "title": "Server Configuration"
          },
          {
            "type": "content",
            "emoji": "⚙️",
            "title": "app.ini Configuration",
            "box": {
              "code": "[server]\nDOMAIN = gitea.example.com\nROOT_URL = https://gitea.example.com/\nHTTP_PORT = 3000\nSSH_DOMAIN = gitea.example.com\nSSH_PORT = 22\n\n[database]\nDB_TYPE = sqlite3\nPATH = /data/gitea/gitea.db\n\n[repository]\nROOT = /data/git/repositories\n\n[session]\nPROVIDER = file\n\n[log]\nMODE = console\nLEVEL = Info",
              "title": "<strong>Main configuration file</strong>"
            },
            "note": {
              "text": "<span class=\"emoji\">💡</span> Configuration can be done via file, environment variables, or command line"
            }
          },
          {
            "type": "content",
            "emoji": "🌐",
            "title": "Reverse Proxy Setup",
            "box": {
              "code": "server {\n    listen 80;\n    server_name gitea.example.com;\n\n    location / {\n        proxy_pass http://localhost:3000;\n        proxy_set_header Host $host;\n        proxy_set_header X-Real-IP $remote_addr;\n        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;\n        proxy_set_header X-Forwarded-Proto $scheme;\n    }\n}\n\n# Caddyfile (even simpler)\ngitea.example.com {\n    reverse_proxy localhost:3000\n}",
              "title": "<strong>Nginx configuration example</strong>"
            }
          }
        ]
      },
