            "type": "content",
            "title": "Modern Cassandra (4.0/5.0)",
            "box": {
              "list": [
                {
                  "emoji": "🏎️",
                  "text": "<strong>Zero Copy Streaming:</strong> 5x faster data movement during rebalancing."
                },
                {
                  "emoji": "🏗️",
                  "text": "<strong>SAI:</strong> Storage Attached Indexing for high-performance secondary queries."
