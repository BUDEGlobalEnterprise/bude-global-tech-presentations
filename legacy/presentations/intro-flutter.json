                {
                  "emoji": "🔄",
                  "text": "<strong>Hot Restart</strong> - Faster than full restart, resets state"
                },
                {
                  "emoji": "🎯",
                  "text": "<strong>Full Restart</strong> - Complete app reload"
                },
                {
                  "emoji": "💡",
                  "text": "<strong>Best for</strong> - UI changes, styling, bug fixes"
                }
